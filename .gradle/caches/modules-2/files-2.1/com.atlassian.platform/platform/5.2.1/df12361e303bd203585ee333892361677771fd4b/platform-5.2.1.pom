<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.atlassian.platform</groupId>
        <artifactId>platform-poms</artifactId>
        <version>5.2.1</version>
    </parent>

    <artifactId>platform</artifactId>
    <packaging>pom</packaging>

    <name>Atlassian Java Platform POM</name>
    <description>POM containing platform modules (libraries + plugins) for inclusion in the product</description>

    <properties>
        <activeobjects.version>3.3.2</activeobjects.version>
        <annotations.version>2.2.2</annotations.version>
        <apl.version>7.2.6</apl.version>
        <atlassian.http.version>2.0.8</atlassian.http.version>
        <atlassian.httpclient.version>2.1.5</atlassian.httpclient.version>
        <atr.version>4.1.3</atr.version>
        <beehive.version>2.0.1</beehive.version>
        <cache.version>4.0.2</cache.version>
        <caesium.version>3.1.2</caesium.version>
        <event.version>4.1.1</event.version>
        <failure-cache.version>2.0.0</failure-cache.version>
        <fugue.version>4.7.2</fugue.version>
        <gadgets.version>4.5.1</gadgets.version>
        <healthcheck.version>6.0.1</healthcheck.version>
        <jquery.version>2.2.4.10</jquery.version>
        <landlord.version>3.0.1</landlord.version>
        <marshalling-api.version>1.0.2</marshalling-api.version>
        <oauth.version>4.1.1</oauth.version>
        <!-- when you change plugins version, make sure spring version in third-party is the same that plugins provides -->
        <plug.version>5.5.1</plug.version>
        <plug.classifier>spring53x</plug.classifier>
        <prettyurls.version>3.0.5</prettyurls.version>
        <rest.version>6.1.10</rest.version>
        <sal.version>4.4.2</sal.version>
        <scheduler.version>3.1.1</scheduler.version>
        <soy.templates.version>5.0.3</soy.templates.version>
        <spring.scanner.version>2.2.2</spring.scanner.version>
        <strm.version>8.3.3</strm.version>
        <tenancy.version>3.0.1</tenancy.version>
        <trust.version>5.0.3</trust.version>
        <util-concurrent.version>4.0.1</util-concurrent.version>
        <!-- When upgrading VCache, upgrade marshalling-api too -->
        <vcache.version>1.13.3</vcache.version>
        <velocity.htmlsafe.version>3.2.1</velocity.htmlsafe.version>
        <webfragments.version>5.1.0</webfragments.version>
        <webhooks.version>6.0.1</webhooks.version>
        <webresource.version>4.3.4</webresource.version>
    </properties>

